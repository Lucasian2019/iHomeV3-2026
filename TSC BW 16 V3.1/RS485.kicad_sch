	(text "#define RS485_EN 21\n\nvoid rs485Transmit()\n{\n    digitalWrite(RS485_EN, HIGH);\n}\n\nvoid rs485Receive()\n{\n    digitalWrite(RS485_EN, LOW);\n}\n\nvoid sendRS485(String msg)\n{\n    rs485Transmit();\n    Serial2.print(msg);\n    Serial2.flush();\n    rs485Receive();\n}"
		(exclude_from_sim no)
		(at 263.398 38.862 0)
